#!/usr/bin/env bash
# Standalone installer for Greenode CLI
# Usage: ./scripts/install [--install-dir <dir>] [--bin-dir <dir>]

set -e

INSTALL_DIR="${HOME}/.local/lib/greenode"
BIN_DIR="${HOME}/.local/bin"

while [ $# -gt 0 ]; do
    case "$1" in
        --install-dir)
            INSTALL_DIR="$2"
            shift 2
            ;;
        --bin-dir)
            BIN_DIR="$2"
            shift 2
            ;;
        *)
            echo "Unknown option: $1"
            exit 1
            ;;
    esac
done

echo "Installing Greenode CLI..."
echo "  Install dir: ${INSTALL_DIR}"
echo "  Bin dir:     ${BIN_DIR}"

# Create virtualenv
python3 -m venv "${INSTALL_DIR}"

# Install grncli into the virtualenv
"${INSTALL_DIR}/bin/pip" install --upgrade pip
"${INSTALL_DIR}/bin/pip" install .

# Create symlink in bin dir
mkdir -p "${BIN_DIR}"
ln -sf "${INSTALL_DIR}/bin/grn" "${BIN_DIR}/grn"

echo ""
echo "Greenode CLI installed successfully!"
echo ""
echo "Make sure ${BIN_DIR} is in your PATH:"
echo "  export PATH=\"${BIN_DIR}:\$PATH\""
echo ""
echo "Run 'grn configure' to set up credentials."
