#!/usr/bin/env bash
# Create a self-contained bundle for offline installation
# Usage: ./scripts/make-bundle
# Output: dist/grncli-bundle.zip

set -e

BUNDLE_DIR="dist/grncli-bundle"

echo "Creating Greenode CLI bundle..."

# Clean
rm -rf "${BUNDLE_DIR}" dist/grncli-bundle.zip

# Build wheel
python setup.py bdist_wheel

# Download all dependencies
mkdir -p "${BUNDLE_DIR}/packages"
pip download -r requirements.txt -d "${BUNDLE_DIR}/packages"
cp dist/*.whl "${BUNDLE_DIR}/packages/"

# Copy install script
cp scripts/install "${BUNDLE_DIR}/install"
chmod +x "${BUNDLE_DIR}/install"

# Create offline installer
cat > "${BUNDLE_DIR}/install-offline" << 'INSTALLER'
#!/usr/bin/env bash
# Offline installer for Greenode CLI
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_DIR="${HOME}/.local/lib/greenode"
BIN_DIR="${HOME}/.local/bin"

echo "Installing Greenode CLI (offline)..."

python3 -m venv "${INSTALL_DIR}"
"${INSTALL_DIR}/bin/pip" install --upgrade pip
"${INSTALL_DIR}/bin/pip" install --no-index --find-links "${SCRIPT_DIR}/packages" grncli

mkdir -p "${BIN_DIR}"
ln -sf "${INSTALL_DIR}/bin/grn" "${BIN_DIR}/grn"

echo ""
echo "Greenode CLI installed successfully!"
echo "Make sure ${BIN_DIR} is in your PATH."
echo "Run 'grn configure' to set up credentials."
INSTALLER
chmod +x "${BUNDLE_DIR}/install-offline"

# Zip it
cd dist && zip -r grncli-bundle.zip grncli-bundle/
cd ..

echo "Bundle created: dist/grncli-bundle.zip"
echo "To install offline: unzip grncli-bundle.zip && cd grncli-bundle && ./install-offline"
